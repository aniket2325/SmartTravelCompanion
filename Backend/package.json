{
    "name": "stc-backend",
    "version": "1.0.0",
    "description": "Smart Travel Companion — Node.js + Express Backend",
    "main": "src/index.js",
    "type": "commonjs",
    "scripts": {
        "kill-port": "powershell -Command \"$p=(Get-NetTCPConnection -LocalPort 5000 -State Listen -EA SilentlyContinue | Select -ExpandProperty OwningProcess -EA SilentlyContinue); if($p){Stop-Process -Id $p -Force; Write-Host 'Port 5000 cleared'}\"",
        "dev": "npm run kill-port & nodemon index.js",
        "start": "node index.js"
    },
    "dependencies": {
        "@google/generative-ai": "^0.21.0",
        "axios": "^1.7.2",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-rate-limit": "^7.3.1",
        "express-validator": "^7.1.0",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.5.1",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "node-cron": "^3.0.3",
        "nodemailer": "^8.0.5",
        "uuid": "^10.0.0"
    },
    "devDependencies": {
        "nodemon": "^3.1.4"
    }
}
